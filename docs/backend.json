
{
  "entities": {
    "Yojana": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Yojana",
      "type": "object",
      "description": "Represents a government scheme, either Central or State, with its details, progress, and public engagement metrics.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Yojana entity."
        },
        "name": {
          "type": "string",
          "description": "The official name of the government scheme."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the scheme, its objectives, and benefits."
        },
        "type": {
          "type": "string",
          "description": "Indicates if the scheme is 'Central' (national) or 'State' specific."
        },
        "ministry": {
          "type": "string",
          "description": "The government ministry or department responsible for the scheme."
        },
        "stateId": {
          "type": "string",
          "description": "Reference to the State entity if the scheme is state-specific."
        },
        "categoryIds": {
          "type": "array",
          "description": "References to Category entities.",
          "items": {
            "type": "string"
          }
        },
        "targetCompletionDate": {
          "type": "string",
          "description": "The target date for the scheme's completion.",
          "format": "date"
        },
        "currentProgressPercentage": {
          "type": "number",
          "description": "The current percentage of completion for the scheme (0-100)."
        },
        "totalUpvotes": {
          "type": "number",
          "description": "The total number of upvotes received for this scheme."
        },
        "totalDownvotes": {
          "type": "number",
          "description": "The total number of downvotes received for this scheme."
        },
        "averageRating": {
          "type": "number",
          "description": "The calculated average 5-star rating for the scheme."
        },
        "totalRatings": {
          "type": "number",
          "description": "The total number of 5-star ratings submitted for this scheme."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the scheme record was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the scheme record was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "type",
        "ministry",
        "targetCompletionDate",
        "currentProgressPercentage",
        "totalUpvotes",
        "totalDownvotes",
        "averageRating",
        "totalRatings",
        "createdAt"
      ]
    },
    "Application": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Application",
      "type": "object",
      "description": "Represents a citizen's application for a specific government scheme.",
      "properties": {
        "id": { "type": "string" },
        "schemeId": { "type": "string" },
        "schemeName": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["Submitted", "Processing", "Approved", "Rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "schemeId", "schemeName", "userId", "status", "timestamp"]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Defines a category for organizing government schemes.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["id", "name", "description"]
    },
    "State": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "State",
      "type": "object",
      "description": "Represents an Indian state for tracking development progress.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "capital": { "type": "string" },
        "overallDevelopmentPercentage": { "type": "number" },
        "colorCode": { "type": "string" }
      },
      "required": ["id", "name", "overallDevelopmentPercentage", "colorCode"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's public profile.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "stateId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "displayName", "createdAt"]
    },
    "Feedback": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Feedback",
      "type": "object",
      "description": "Stores public feedback or ideas.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "yojanaId": { "type": "string" },
        "type": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "content", "createdAt"]
    },
    "SchemeVote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SchemeVote",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "yojanaId": { "type": "string" },
        "voteType": { "type": "string", "enum": ["Upvote", "Downvote"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "yojanaId", "voteType", "createdAt"]
    },
    "PollVote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PollVote",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "pollId": { "type": "string" },
        "pollOptionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "pollId", "pollOptionId", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com",
      "anonymous"
    ]
  },
  "firestore": {
    "/yojanaye/{yojanaId}": {
      "schema": "Yojana",
      "description": "Stores details for each government scheme."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Defines categories for organizing government schemes."
    },
    "/states/{stateId}": {
      "schema": "State",
      "description": "Contains data for Indian states."
    },
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "Stores public profile information for each user."
    },
    "/userProfiles/{userId}/applications/{appId}": {
      "schema": "Application",
      "description": "Stores scheme applications for a user."
    },
    "/userProfiles/{userId}/schemeVotes/{yojanaId}": {
      "schema": "SchemeVote",
      "description": "Records an individual user's upvote or downvote for a specific government scheme."
    },
    "/userProfiles/{userId}/pollVotes/{pollId}": {
      "schema": "PollVote",
      "description": "Records an individual user's vote on a specific poll option."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Stores public feedback and ideas submitted by users."
    }
  }
}
