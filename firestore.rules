
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // User Profiles and Subcollections
    match /userProfiles/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();

      match /applications/{appId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      
      match /schemeRatings/{ratingId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      
      match /schemeVotes/{voteId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      
      match /pollVotes/{voteId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    // Scheme Feedback (Mixed Public/Private)
    match /schemeFeedback/{feedbackId} {
      allow read: if true; // Publicly readable for the stream
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Public Ideas
    match /publicIdeas/{publicIdeaId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Static Collections (Schemes, States, Categories)
    match /schemes/{schemeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /states/{stateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Polls and Options
    match /polls/{pollId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /pollOptions/{optionId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // National Snapshots
    match /nationalProgressSnapshots/{snapshotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin Roles (Existence check)
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
    }
  }
}
